#!/usr/bin/env bash
# gpu-cr-restore-agentd — host daemon that auto-triggers the GPU restore.
#
# Why not an OCI poststart hook: crun does NOT run poststart hooks on the CRIU
# restore path, so a restore-annotated container comes up with the app suspended
# (cuda-checkpoint state "checkpointed") and nothing drives the GPU restore.
#
# This daemon polls the runtime for containers that (a) carry gpu-cr.io/restore=true
# in their OCI config (put there by the CRI-O staging patch) and (b) whose GPU
# process is in the "checkpointed" state, and runs the race-free restore sequence
# (gpu-restore.sh: cuda-checkpoint restore -> gate -> unlock -> data remap).
# It needs no Kubernetes API — everything comes from the runtime state + config.json.
set -u
CRUN="${GCR_CRUN:-/usr/libexec/crio/crun}"
CRUN_ROOT="${GCR_CRUN_ROOT:-/run/crun}"
CUDA_CHECKPOINT_BIN="${CUDA_CHECKPOINT_BIN:-/usr/bin/cuda-checkpoint}"
LIBDIR="${GCR_LIBDIR:-/usr/local/lib/gpu-cr-restore/hooks/lib}"
STATE_DIR="${GCR_AGENT_STATE:-/var/lib/gpu-cr/restore-agent}"
POLL="${GCR_AGENT_POLL:-2}"
export CUDA_CHECKPOINT_BIN
mkdir -p "${STATE_DIR}"

# shellcheck source=/dev/null
. "${LIBDIR}/common.sh"
# shellcheck source=/dev/null
. "${LIBDIR}/gpu-restore.sh"

_state_field() {  # <cid> <python-expr on d>
  "${CRUN}" --root "${CRUN_ROOT}" state "$1" 2>/dev/null \
    | python3 -c "import json,sys;d=json.load(sys.stdin);print($2)" 2>/dev/null
}

gcr_log "restore-agent started (crun=${CRUN} root=${CRUN_ROOT} poll=${POLL}s)"
while true; do
  for cid in $("${CRUN}" --root "${CRUN_ROOT}" list 2>/dev/null | awk 'NR>1 && $3=="running"{print $1}'); do
    [ -f "${STATE_DIR}/${cid}.done" ] && continue
    bundle="$(_state_field "${cid}" "d.get('bundle','')")"
    cfg="${bundle}/config.json"
    [ -f "${cfg}" ] || continue
    [ "$(gcr_annotation "${cfg}" 'gpu-cr.io/restore')" = "true" ] || continue

    pid="$(_state_field "${cid}" "d.get('pid',0)")"
    [ "${pid:-0}" -gt 0 ] 2>/dev/null || continue
    gpupid="$(gcr_find_cuda_pid "${pid}")"
    [ "$(${CUDA_CHECKPOINT_BIN} --get-state --pid "${gpupid}" 2>/dev/null)" = "checkpointed" ] || continue

    srcuid="$(gcr_annotation "${cfg}" 'gpu-cr.io/source-pod-uid')"
    gcr_log "restore-agent: restoring container ${cid:0:12} (pid=${pid} gpu-pid=${gpupid} uid=${srcuid})"
    if gcr_gpu_restore "${pid}" "${srcuid}"; then
      touch "${STATE_DIR}/${cid}.done"
      gcr_log "restore-agent: container ${cid:0:12} restored"
    else
      gcr_log "restore-agent: restore failed for ${cid:0:12}; will retry"
    fi
  done
  sleep "${POLL}"
done
