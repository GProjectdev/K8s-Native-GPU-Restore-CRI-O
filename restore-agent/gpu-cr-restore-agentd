#!/usr/bin/env bash
# gpu-cr-restore-agentd — host daemon that auto-triggers the GPU DATA remap after
# a CRIUgpu restore.
#
# Why a daemon (not an OCI poststart hook): crun does NOT run poststart hooks on
# the CRIU restore path, so a restore-annotated container comes up with nothing to
# drive the GPU data remap.
#
# main branch (CRIUgpu): the GPU CONTROL STATE and the CPU process are restored by
# CRI-O + CRIU + the NVIDIA cuda_plugin during the native restore — there is NO host
# cuda-checkpoint step and the restored process is already *running*. So detection
# can no longer key off cuda-checkpoint's "checkpointed" state (that state no longer
# exists here). Instead we simply look for containers that carry gpu-cr.io/restore=true
# in their OCI config (put there by the CRI-O staging patch) and haven't been handled
# yet, and drive the interceptor DATA remap.
#
# Race-free without a cuda-checkpoint lock: the in-Pod interceptor arms its RESTORE
# GATE at checkpoint *freeze* time, so CRIU captures gate=1. The restored process
# therefore comes up already blocked at its first GPU kernel launch and stays blocked
# until this remap completes — the daemon's poll latency is harmless.
#
# (v1.0 branch drove a host cuda-checkpoint helper for the control state instead.)
set -u
CRUN="${GCR_CRUN:-/usr/libexec/crio/crun}"
CRUN_ROOT="${GCR_CRUN_ROOT:-/run/crun}"
LIBDIR="${GCR_LIBDIR:-/usr/local/lib/gpu-cr-restore/hooks/lib}"
STATE_DIR="${GCR_AGENT_STATE:-/var/lib/gpu-cr/restore-agent}"
DATA_DIR="${GCR_DATA_DIR:-/var/lib/gcr-data}"   # where the interceptor re-reads the GPU data blob
POLL="${GCR_AGENT_POLL:-2}"
mkdir -p "${STATE_DIR}"

# shellcheck source=/dev/null
. "${LIBDIR}/common.sh"
# shellcheck source=/dev/null
. "${LIBDIR}/gpu-restore.sh"

_state_field() {  # <cid> <python-expr on d>
  "${CRUN}" --root "${CRUN_ROOT}" state "$1" 2>/dev/null \
    | python3 -c "import json,sys;d=json.load(sys.stdin);print($2)" 2>/dev/null
}

gcr_log "restore-agent started (CRIUgpu; crun=${CRUN} root=${CRUN_ROOT} poll=${POLL}s)"
while true; do
  for cid in $("${CRUN}" --root "${CRUN_ROOT}" list 2>/dev/null | awk 'NR>1 && $3=="running"{print $1}'); do
    [ -f "${STATE_DIR}/${cid}.done" ] && continue
    bundle="$(_state_field "${cid}" "d.get('bundle','')")"
    cfg="${bundle}/config.json"
    [ -f "${cfg}" ] || continue
    [ "$(gcr_annotation "${cfg}" 'gpu-cr.io/restore')" = "true" ] || continue

    pid="$(_state_field "${cid}" "d.get('pid',0)")"
    [ "${pid:-0}" -gt 0 ] 2>/dev/null || continue

    srcuid="$(gcr_annotation "${cfg}" 'gpu-cr.io/source-pod-uid')"
    # The interceptor re-maps GPU data from ${GCR_DATA_DIR}/<uid>/data.blob (CRI-O
    # stages it there at restore). Best-effort visibility if it is missing/empty.
    blob="${DATA_DIR}/${srcuid}/data.blob"
    if [ -n "${srcuid}" ] && [ ! -s "${blob}" ]; then
      gcr_log "restore-agent: WARN GPU data blob missing/empty at ${blob}; remap will fail (cross-node: ensure the .blob was staged next to the tar)"
    fi
    gcr_log "restore-agent: remapping GPU data for ${cid:0:12} (pid=${pid} uid=${srcuid}); control already restored by CRIUgpu"
    if gcr_gpu_restore "${pid}" "${srcuid}"; then
      touch "${STATE_DIR}/${cid}.done"
      gcr_log "restore-agent: container ${cid:0:12} restored"
    else
      gcr_log "restore-agent: remap failed for ${cid:0:12}; will retry"
    fi
  done
  sleep "${POLL}"
done
