#!/usr/bin/env bash
# gpu-cr-restore-hook — OCI poststart hook. CRI-O runs it after the container
# process is (re)started. For a restored GPU container it performs steps 5/6/7:
#   5  GPU control state restore  (cuda-checkpoint --restore, via host helper)
#   6  GPU data-buffer remap      (interceptor: same VA + H2D)
#   7  the app's CUDA calls unblock
#
# The OCI runtime delivers the container STATE as JSON on stdin:
#   { "id": "...", "pid": 1234, "bundle": "/path", "annotations": {...} }
# We read the pid and the source-pod-uid annotation (from the bundle config.json
# for robustness) and delegate to the shared gpu-restore engine.
set -euo pipefail
GCR_LIBDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib"
. "${GCR_LIBDIR}/common.sh"
. "${GCR_LIBDIR}/gpu-restore.sh"

STATE="$(cat)"
read_json() { # read_json <json> <python-expr-on d>
  printf '%s' "$1" | python3 -c "import json,sys; d=json.load(sys.stdin); print($2)" 2>/dev/null || true
}

PID="$(read_json "${STATE}" 'd.get("pid","")')"
BUNDLE="$(read_json "${STATE}" 'd.get("bundle","")')"
# Prefer annotations from the bundle's config.json (authoritative).
SRC_UID=""
if [ -n "${BUNDLE}" ] && [ -f "${BUNDLE}/config.json" ]; then
  SRC_UID="$(gcr_annotation "${BUNDLE}/config.json" 'gpu-cr.io/source-pod-uid')"
  RESTORE="$(gcr_annotation "${BUNDLE}/config.json" 'gpu-cr.io/restore')"
else
  SRC_UID="$(read_json "${STATE}" 'd.get("annotations",{}).get("gpu-cr.io/source-pod-uid","")')"
  RESTORE="$(read_json "${STATE}" 'd.get("annotations",{}).get("gpu-cr.io/restore","")')"
fi

if [ "${RESTORE:-}" != "true" ]; then
  gcr_log "poststart: not a gpu-cr restore; nothing to do"
  exit 0
fi

gcr_log "poststart GPU restore: pid=${PID} src-uid=${SRC_UID:-<none>}"
gcr_gpu_restore "${PID}" "${SRC_UID}" || gcr_log "WARN: GPU restore reported an error"
exit 0
