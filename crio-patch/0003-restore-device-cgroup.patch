+	// gpu-cr: re-add the checkpoint's devices (e.g. /dev/nvidia*) to the container
+	// config so CRI-O restores the device cgroup allow-rules. Without this, crun
+	// restore leaves the device cgroup at deny-all and the GPU is inaccessible
+	// (open EPERM / cuInit CUDA_ERROR_NO_DEVICE) even for a privileged container.
+	if dumpSpec.Linux != nil {
+		for i := range dumpSpec.Linux.Devices {
+			d := dumpSpec.Linux.Devices[i]
+			containerConfig.Devices = append(containerConfig.Devices, &types.Device{
+				ContainerPath: d.Path,
+				HostPath:      d.Path,
+				Permissions:   "rwm",
+			})
+		}
+	}
+
 	if dumpSpec.Linux != nil {
 		if dumpSpec.Linux.MaskedPaths != nil {
