diff --git a/server/container_restore.go b/server/container_restore.go
index e214685..d723edc 100644
--- a/server/container_restore.go
+++ b/server/container_restore.go
@@ -246,6 +246,36 @@ func (s *Server) CRImportCheckpoint(
 		Labels: createLabels,
 	}
 
+	// gpu-cr: propagate the restore Pod's gpu-cr.io/* annotations onto the restored
+	// container so the poststart hook (when.annotations gpu-cr.io/restore=true) fires
+	// and can read gpu-cr.io/source-pod-uid. The restore rebuilds annotations from the
+	// checkpoint image, which do NOT carry the restore request's annotations.
+	for k, v := range createConfig.GetAnnotations() {
+		if strings.HasPrefix(k, "gpu-cr.io/") {
+			if containerConfig.Annotations == nil {
+				containerConfig.Annotations = map[string]string{}
+			}
+			containerConfig.Annotations[k] = v
+		}
+	}
+
+	// gpu-cr: point crun at a CRIU RPC config file so restore honors options that
+	// CRI-O/conmon does NOT pass through to crun restore -- notably tcp-close (and
+	// ext-unix-sk) for a workload that held a socket at checkpoint. crun reads the
+	// org.criu.config annotation and loads that file; the global /etc/criu/crun.conf
+	// lookup is NOT honored on the conmon->crun path. Override per-restore with the
+	// gpu-cr.io/criu-config annotation.
+	if createConfig.GetAnnotations()["gpu-cr.io/restore"] == "true" {
+		if containerConfig.Annotations == nil {
+			containerConfig.Annotations = map[string]string{}
+		}
+		criuCfg := createConfig.GetAnnotations()["gpu-cr.io/criu-config"]
+		if criuCfg == "" {
+			criuCfg = "/etc/criu/crun.conf"
+		}
+		containerConfig.Annotations["org.criu.config"] = criuCfg
+	}
+
 	if createConfig.GetLinux() != nil {
 		if createConfig.GetLinux().GetResources() != nil {
 			containerConfig.Linux.Resources = createConfig.GetLinux().GetResources()
